    "review::.::holistic::incomplete_migration::holistic::src/pipeline/orchestrator.py::generator_uses_httpx_directly": {
      "id": "review::.::holistic::incomplete_migration::holistic::src/pipeline/orchestrator.py::generator_uses_httpx_directly",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "orchestrator.py calls generator via httpx directly but generator.py now uses ArticleGenerator with a client abstraction \u2014 dual code paths for the same operation",
      "detail": {
        "holistic": true,
        "dimension": "incomplete_migration",
        "related_files": [
          "src/pipeline/orchestrator.py",
          "src/articles/generator.py"
        ],
        "evidence": [
          "run_pipeline() calls generator.generate(topic) in a for loop",
          "ArticleGenerator.generate_batch() already does this loop",
          "Two code paths for the same operation creates drift risk"
        ],
        "suggestion": "orchestrator.py's run_pipeline() should instantiate ArticleGenerator and call generate_batch() rather than managing the loop itself. Currently the orchestrator re-implements batch iteration that already exists in generate_batch(). One path should own the batch loop.",
        "reasoning": "",
        "summary_hash": "415e1d6a"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-12T08:42:27+00:00",
